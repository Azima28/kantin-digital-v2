  BackgroundColor #FAFAFA
  FontName "Segoe UI"
  FontColor #2D3748
}
sequenceDiagram {
  participant {
    RoundCorner 8
    BackgroundColor #FFFFFF
    LineColor #CBD5E0
    FontColor #2D3748
    FontSize 11
    
    .siswa {
      BackgroundColor #EBF8FF
      LineColor #3182CE
      FontColor #2B6CB0
    }
    .petugas {
      BackgroundColor #FEFCBF
      LineColor #D69E2E
      FontColor #975A16
    }
    .admin {
      BackgroundColor #E6FFFA
      LineColor #319795
      FontColor #234E52
    }
  }
  actor {
    BackgroundColor #EBF8FF
    LineColor #3182CE
    FontColor #2B6CB0
    
    .siswa {
      BackgroundColor #EBF8FF
      LineColor #3182CE
      FontColor #2B6CB0
    }
    .petugas {
      BackgroundColor #FEFCBF
      LineColor #D69E2E
      FontColor #975A16
    }
