    {
      "id": "02",
      "title": "Class Diagram — Sistem Kantin Digital",
      "type": "class_diagram",
      "description": "Struktur objek data logis sistem kantin beserta model enum yang digunakan.",
      "nodes": [
        { "id": "C_User", "label": "User", "attributes": ["id: UUID <<PK>>", "email: String <<UK>>", "password_hash: String", "full_name: String", "role: UserRole", "is_active: Boolean", "created_at: Timestamp"], "color": "system_backend", "emoji": "👤" },
        { "id": "C_School", "label": "School", "attributes": ["id: UUID <<PK>>", "name: String", "address: String", "logo_url: String", "is_active: Boolean", "created_at: Timestamp"], "color": "system_backend", "emoji": "🏫" },
        { "id": "C_Student", "label": "Student", "attributes": ["id: UUID <<PK>>", "user_id: UUID <<FK>>", "school_id: UUID <<FK>>", "nis: String <<UK>>", "balance: Decimal", "card_uid: String <<UK>>", "is_card_frozen: Boolean", "is_active: Boolean"], "color": "siswa_ortu", "emoji": "🎓" },
        { "id": "C_CanteenOperator", "label": "CanteenOperator", "attributes": ["id: UUID <<PK>>", "user_id: UUID <<FK>>", "school_id: UUID <<FK>>", "stall_name: String", "is_active: Boolean"], "color": "petugas_kasir", "emoji": "🏪" },
        { "id": "C_Product", "label": "Product", "attributes": ["id: UUID <<PK>>", "canteen_operator_id: UUID <<FK>>", "name: String", "price: Decimal", "image_url: String", "is_available: Boolean"], "color": "petugas_kasir", "emoji": "🍔" },
        { "id": "C_Transaction", "label": "Transaction", "attributes": ["id: UUID <<PK>>", "student_id: UUID <<FK>>", "type: TxType", "amount: Decimal", "performed_by: UUID <<FK>>", "method: TxMethod", "status: TxStatus", "notes: String", "created_at: Timestamp"], "color": "admin_keuangan", "emoji": "💸" },
        { "id": "C_TransactionItem", "label": "TransactionItem", "attributes": ["id: UUID <<PK>>", "transaction_id: UUID <<FK>>", "product_id: UUID <<FK>>", "name: String", "price: Decimal", "quantity: Int", "subtotal: Decimal"], "color": "admin_keuangan", "emoji": "🧾" },
        { "id": "C_AuditLog", "label": "AuditLog", "attributes": ["id: UUID <<PK>>", "user_id: UUID <<FK>>", "action: String", "target_table: String", "target_id: UUID", "old_value: JSON", "new_value: JSON", "ip_address: String", "created_at: Timestamp"], "color": "admin_keuangan", "emoji": "📜" }
      ],
      "enums": [
        { "name": "UserRole", "values": ["super_admin", "admin_keuangan", "siswa", "petugas_kantin"], "emoji": "🏷️" },
        { "name": "TxType", "values": ["topup_online", "topup_cash", "purchase", "refund", "adjustment"], "emoji": "🏷️" },
        { "name": "TxMethod", "values": ["midtrans", "cash", "nfc_tap", "manual"], "emoji": "🏷️" },
        { "name": "TxStatus", "values": ["pending", "success", "failed", "refunded"], "emoji": "🏷️" }
      ],
      "connections": [
        { "from": "C_User", "to": "C_Student", "label": "has (1 to 0..1)" },
        { "from": "C_User", "to": "C_CanteenOperator", "label": "has (1 to 0..1)" },
        { "from": "C_School", "to": "C_Student", "label": "enrolls (1 to *)" },
        { "from": "C_School", "to": "C_CanteenOperator", "label": "employs (1 to *)" },
        { "from": "C_CanteenOperator", "to": "C_Product", "label": "manages (1 to *)" },
        { "from": "C_Student", "to": "C_Transaction", "label": "makes (1 to *)" },
        { "from": "C_Transaction", "to": "C_TransactionItem", "label": "contains (1 to *)" },
        { "from": "C_Product", "to": "C_TransactionItem", "label": "references (0..1 to *)" },
        { "from": "C_User", "to": "C_AuditLog", "label": "generates (1 to *)" }
      ]
    },
    {
      "id": "03",
      "title": "ER Diagram — Sistem Kantin Digital",
      "type": "er_diagram",
      "description": "Desain database PostgreSQL fisik dengan kunci PK, FK, UK dan constraint.",
      "nodes": [
        { "id": "E_users", "label": "users", "fields": ["PK id: uuid", "UK email: varchar", "password_hash: varchar", "full_name: varchar", "role: enum_role", "is_active: boolean", "created_at: timestamptz"], "color": "system_backend", "emoji": "🔑" },
        { "id": "E_schools", "label": "schools", "fields": ["PK id: uuid", "name: varchar", "address: text", "logo_url: varchar", "is_active: boolean", "created_at: timestamptz"], "color": "system_backend", "emoji": "🏢" },
        { "id": "E_students", "label": "students", "fields": ["PK id: uuid", "FK user_id: uuid", "FK school_id: uuid", "UK nis: varchar", "balance: numeric (>=0)", "UK card_uid: varchar", "is_card_frozen: boolean", "is_active: boolean"], "color": "siswa_ortu", "emoji": "🎒" },
        { "id": "E_canteen_operators", "label": "canteen_operators", "fields": ["PK id: uuid", "FK user_id: uuid", "FK school_id: uuid", "stall_name: varchar", "is_active: boolean"], "color": "petugas_kasir", "emoji": "🏠" },
        { "id": "E_products", "label": "products", "fields": ["PK id: uuid", "FK canteen_operator_id: uuid", "name: varchar", "price: numeric", "image_url: varchar", "is_available: boolean"], "color": "petugas_kasir", "emoji": "🍕" },
        { "id": "E_transactions", "label": "transactions", "fields": ["PK id: uuid", "FK student_id: uuid", "type: enum_tx_type", "amount: numeric", "performed_by: uuid", "method: enum_tx_method", "status: enum_tx_status", "notes: text", "created_at: timestamptz"], "color": "admin_keuangan", "emoji": "📊" },
        { "id": "E_transaction_items", "label": "transaction_items", "fields": ["PK id: uuid", "FK transaction_id: uuid", "FK product_id: uuid", "name: varchar", "price: numeric", "quantity: integer", "subtotal: numeric"], "color": "admin_keuangan", "emoji": "🏷️" },
        { "id": "E_audit_logs", "label": "audit_logs", "fields": ["PK id: uuid", "FK user_id: uuid", "action: varchar", "target_table: varchar", "target_id: uuid", "old_value: jsonb", "new_value: jsonb", "ip_address: varchar", "created_at: timestamptz"], "color": "admin_keuangan", "emoji": "📒" }
      ],
      "connections": [
        { "from": "E_users", "to": "E_students", "cardinality": "1 to 0..1" },
        { "from": "E_users", "to": "E_canteen_operators", "cardinality": "1 to 0..1" },
        { "from": "E_schools", "to": "E_students", "cardinality": "1 to many" },
        { "from": "E_schools", "to": "E_canteen_operators", "cardinality": "1 to many" },
        { "from": "E_canteen_operators", "to": "E_products", "cardinality": "1 to many" },
        { "from": "E_students", "to": "E_transactions", "cardinality": "1 to many" },
        { "from": "E_transactions", "to": "E_transaction_items", "cardinality": "1 to many" },
        { "from": "E_products", "to": "E_transaction_items", "cardinality": "1 to many" },
        { "from": "E_users", "to": "E_audit_logs", "cardinality": "1 to many" }
      ]
    },
    {
      "id": "04",
      "title": "Sequence Diagram — Alur Transaksi NFC",
      "type": "sequence_diagram",
      "description": "Menampilkan validasi berlapis (client dan server-side) saat melakukan tap pembayaran kartu NFC.",
      "lifelines": [
        { "id": "Siswa", "label": "Siswa (Kartu NFC)", "color": "siswa_ortu", "emoji": "🪪" },
        { "id": "POS", "label": "App POS Mobile (Kasir)", "color": "petugas_kasir", "emoji": "📱" },
        { "id": "DB", "label": "Supabase DB (Backend)", "color": "system_backend", "emoji": "☁️" }
      ],
      "messages": [
        { "from": "POS", "note": "Petugas memilih produk ke keranjang (Cart)", "emoji": "🛒" },
        { "from": "Siswa", "to": "POS", "label": "1. Tap Kartu RFID/NFC", "emoji": "📡" },
        { "from": "POS", "to": "DB", "label": "2. Query Saldo (Card UID)", "emoji": "🔍" },
        { "from": "DB", "to": "POS", "label": "3. Return Nama & Saldo Terbaru", "emoji": "↩️" },
        { "from": "POS", "note": "4. Cek local: Saldo >= Total Belanja?", "emoji": "⚖️" },
        { "type": "alt", "conditions": [
          { "name": "Saldo Cukup", "steps": [
            { "from": "POS", "to": "DB", "label": "5. Jalankan Transaksi (ACID Stored Procedure)", "emoji": "⚡" },
            { "from": "DB", "note": "6. Server validation: Validasi ulang harga riil & cek batas saldo", "emoji": "🔒" },
            { "from": "DB", "to": "POS", "label": "7. Return Transaksi Sukses", "emoji": "✅" },
            { "from": "POS", "to": "Siswa", "label": "8. Tampil Sukses & Getar HP", "emoji": "📲" },
            { "from": "DB", "to": "Siswa", "label": "9. Push Notification ke HP Siswa", "emoji": "🔔" }
          ]},
          { "name": "Saldo Tidak Cukup", "steps": [
            { "from": "POS", "to": "Siswa", "label": "Layar POS Merah - Transaksi Ditolak", "emoji": "❌" }
          ]}
        ]}
      ]
    },
