{
  "projectName": "Sistem Kantin Digital",
  "techStack": "Flutter (Mobile & Web) + Supabase (PostgreSQL DB)",
  "globalStyling": {
    "fontFamily": "Segoe UI",
    "shadows": false,
    "themeColors": {
      "siswa_ortu": { "fill": "#DAE8FC", "stroke": "#6C8EBF", "text": "#0A2540", "emoji": "🔵" },
      "petugas_kasir": { "fill": "#FFE6CC", "stroke": "#D79B00", "text": "#5A3200", "emoji": "🟡" },
      "admin_keuangan": { "fill": "#D5E8D4", "stroke": "#72B095", "text": "#0A3F2C", "emoji": "🟢" },
      "system_backend": { "fill": "#E6F2F2", "stroke": "#0E8A8A", "text": "#0E8A8A", "emoji": "⚙️" }
    }
  },
  "diagram": {
    "title": "07. Context Diagram (DFD Level 0)",
    "type": "context_diagram",
    "description": "Aliran data masuk dan keluar dari external entity ke pusat sistem kantin.",
    "centralSystem": { "id": "system", "label": "SISTEM KANTIN\nDIGITAL", "shape": "double_ellipse", "emoji": "💻" },
    "entities": [
      { "id": "AC_Siswa", "label": "Siswa", "color": "siswa_ortu", "emoji": "👦" },
      { "id": "AC_Ortu", "label": "Orang Tua", "color": "siswa_ortu", "emoji": "👩" },
      { "id": "AC_Petugas", "label": "Petugas Kantin", "color": "petugas_kasir", "emoji": "👵" },
      { "id": "AC_Admin", "label": "Admin Keuangan", "color": "admin_keuangan", "emoji": "👨‍💼" },
      { "id": "AC_Super", "label": "Super Admin", "color": "admin_keuangan", "emoji": "👑" }
    ],
    "flows": [
      { "from": "AC_Siswa", "to": "system", "label": "In: Req Jajan / UID NFC\nOut: Info Saldo, Notifikasi", "bidirectional": true, "color": "siswa_ortu" },
      { "from": "AC_Ortu", "to": "system", "label": "In: Cek NIS, Bayar Top-up\nOut: E-Receipt, Saldo", "bidirectional": true, "color": "siswa_ortu" },
      { "from": "AC_Petugas", "to": "system", "label": "In: Pilih Menu, Total POS\nOut: Data Siswa, Transaksi Sukses", "bidirectional": true, "color": "petugas_kasir" },
      { "from": "AC_Admin", "to": "system", "label": "In: Top-up Cash, Koreksi Saldo\nOut: Laporan Keuangan, Struk", "bidirectional": true, "color": "admin_keuangan" },
      { "from": "AC_Super", "to": "system", "label": "In: Blokir User, CRUD Sekolah\nOut: Live Audit Logs, Stats", "bidirectional": true, "color": "admin_keuangan" }
    ]
  }
}
